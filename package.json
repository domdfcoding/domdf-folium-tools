{
  "name": "domdf-folium-tools",
  "version": "0.1.0b4",
  "description": "Miscellaneous utilities for folium/leaflet.",
  "homepage": "https://github.com/domdfcoding/domdf-folium-tools",
  "keywords": [
    "leaflet",
    "plugin"
  ],
  "type": "module",
  "author": "Dominic Davis-Foster",
  "repository": {
    "type": "git",
    "url": "https://github.com/domdfcoding/domdf-folium-tools.git"
  },
  "main": "domdf_folium_tools/domdf-folium-tools.js",
  "devDependencies": {
    "@types/leaflet": "^1.9.20",
    "@types/leaflet.markercluster": "^1.5.6",
    "esbuild": "0.28.0",
    "ts-loader": "^9.5.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "license-report": "^6.8.0"
  },
  "scripts": {
    "prepare": "esbuild src/main.ts --bundle --outfile=domdf_folium_tools/domdf-folium-tools.js --external:leaflet --minify",
    "build": "esbuild src/main.ts --bundle --outfile=domdf_folium_tools/domdf-folium-tools.js --external:leaflet",
    "build_esm": "esbuild src/main.ts --bundle --outfile=domdf_folium_tools/domdf-folium-tools.js --external:leaflet --format=esm"
  },
  "license": "MIT",
  "files": [
    "domdf_folium_tools/domdf-folium-tools.js",
    "src"
  ],
  "jshintConfig": {
    "quotmark": "single",
    "globals": {
      "L": true
    },
    "trailing": true,
    "camelcase": true,
    "curly": true,
    "eqeqeq": true,
    "noempty": true,
    "nonbsp": true,
    "undef": true,
    "unused": true,
    "browser": true
  }
}
